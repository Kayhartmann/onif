#!/usr/bin/with-contenv bashio
# ==============================================================================
# Service: neolink (Reolink Baichuan → RTSP bridge)
# Includes memory watchdog: restarts neolink if RSS exceeds MEM_LIMIT_KB
# to prevent OOM kills (known neolink memory leak ~1.8 GB before OOM).
# ==============================================================================

# Kill any stale neolink from a previous run (host_network: port stays bound)
pkill -x neolink 2>/dev/null && sleep 1 || true

CONFIG_FILE="/data/neolink/neolink.toml"
LOG_LEVEL=$(bashio::config 'log_level')
MEM_LIMIT_KB=614400   # 600 MB — restart well before OOM at ~1.8 GB

# Map HA log level to Neolink log level
case "${LOG_LEVEL}" in
    "error") NEOLINK_LOG="error" ;;
    "warn")  NEOLINK_LOG="warn" ;;
    "info")  NEOLINK_LOG="info" ;;
    "debug") NEOLINK_LOG="debug,neolink=debug,neolink_core=info" ;;
    *)       NEOLINK_LOG="info" ;;
esac

bashio::log.info "Starting Neolink (log level: ${NEOLINK_LOG}, mem limit: $((MEM_LIMIT_KB / 1024)) MB)..."

export RUST_LOG="${NEOLINK_LOG}"
export GST_DEBUG_NO_COLOR=1
export GST_DEBUG=2

neolink rtsp --config "${CONFIG_FILE}" &
NEOLINK_PID=$!

# Forward s6 stop signal (SIGTERM) cleanly to neolink
trap "bashio::log.info 'Neolink stop requested.'; kill -TERM ${NEOLINK_PID} 2>/dev/null; wait ${NEOLINK_PID} 2>/dev/null; exit 0" TERM INT

# Memory watchdog loop
while kill -0 "${NEOLINK_PID}" 2>/dev/null; do
    sleep 30 &
    wait $! 2>/dev/null   # interruptible by trap

    RSS=$(awk '/VmRSS/{print $2}' "/proc/${NEOLINK_PID}/status" 2>/dev/null || echo 0)
    if [ "${RSS}" -gt "${MEM_LIMIT_KB}" ]; then
        bashio::log.warning "Neolink RAM: ${RSS} kB > ${MEM_LIMIT_KB} kB limit — restarting to prevent OOM kill..."
        kill -TERM "${NEOLINK_PID}" 2>/dev/null || true
        sleep 3
        kill -KILL "${NEOLINK_PID}" 2>/dev/null || true
    fi
done

wait "${NEOLINK_PID}" 2>/dev/null
